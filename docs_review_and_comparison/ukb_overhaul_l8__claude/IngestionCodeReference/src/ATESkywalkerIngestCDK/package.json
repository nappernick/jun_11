  "devDependencies": {
    "@amzn/lily-cdk-pipeline-visualize": "*",
    "@amzn/personal-stacks": "^4.0.25",
    "@opensearch-project/opensearch": "^2.3.0",
    "@aws-sdk/credential-provider-node": "^3.0.0",
    "@types/node": "20.10.x",
    "@typescript-eslint/eslint-plugin": "^5.30.0",
    "@typescript-eslint/parser": "^5.30.0",
    "eslint": "^8.23.0",
    "eslint-config-prettier": "^8.5.0",
    "esbuild": "^0.20.0",
    "prettier": "^2.7.1",
    "typescript": "~5.0.3",
