        "children": [
          {
            "text": "CIBT visas page"
          }
        ],
        "id": "",
        "anchorId": ""
      },
      {
        "text": " and click on the "
      },
      {
        "text": "Don\u2019t reside in one of these countries?",
        "bold": true
      },
      {
        "text": "\u00a0button at the bottom of the page for guidance."
      }
    ],
